<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>MNDI Workspace</title>
    <!-- Google Material Icons -->
    <link href="https://googleapis.com" rel="stylesheet">
    <style>
        :root {
            --bg-main: #f8fafc;
            --bg-side: #ffffff;
            --primary: #1a73e8; /* Windows & Google風アクセント */
            --primary-hover: #1557b0;
            --text-main: #1e293b;
            --text-sub: #64748b;
            --border: #e2e8f0;
            --shadow: 0 4px 12px rgba(0,0,0,0.05);
            --radius: 12px;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
            background-color: var(--bg-main);
            color: var(--text-main);
            overflow: hidden;
            height: 100vh;
            display: flex;
        }

        /* 画面切り替え管理 */
        .app-view { display: none; width: 100%; height: 100%; }
        .app-view.active { display: flex; }

        /* ==========================================================================
           1. 認証画面（サインイン / サインアップ共通）
           ========================================================================== */
        #authView {
            justify-content: center;
            align-items: center;
            background: linear-gradient(135deg, #eef2f7, #e0e7ff);
        }
        .auth-card {
            background: #ffffff;
            padding: 40px;
            border-radius: 24px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
            width: 100%;
            max-width: 400px;
            text-align: center;
        }
        .auth-logo {
            font-weight: bold;
            font-size: 28px;
            letter-spacing: 1px;
            margin-bottom: 8px;
            color: #0f172a;
        }
        .auth-subtitle { color: var(--text-sub); margin-bottom: 32px; font-size: 14px;}
        .auth-input-group { text-align: left; margin-bottom: 20px; }
        .auth-input-group label { display: block; font-size: 12px; font-weight: 600; margin-bottom: 6px; color: var(--text-sub); }
        .auth-input {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            font-size: 15px;
            outline: none;
            transition: border 0.2s;
        }
        .auth-input:focus { border-color: var(--primary); }
        .auth-btn {
            width: 100%;
            padding: 14px;
            background-color: var(--primary);
            color: white;
            border: none;
            border-radius: var(--radius);
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
            transition: background 0.2s;
        }
        .auth-btn:hover { background-color: var(--primary-hover); }
        
        /* 新規登録・ログイン切り替えリンク */
        .auth-toggle-link {
            margin-top: 20px;
            font-size: 14px;
            color: var(--primary);
            cursor: pointer;
            display: inline-block;
        }
        .auth-toggle-link:hover { text-decoration: underline; }

        /* ==========================================================================
           共通レイアウト (Sidebar & Main)
           ========================================================================== */
        .sidebar {
            width: 260px;
            background-color: var(--bg-side);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 24px 16px;
        }
        .sidebar-logo {
            font-weight: bold;
            font-size: 22px;
            padding-left: 12px;
            margin-bottom: 32px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px;
            border-radius: var(--radius);
            cursor: pointer;
            color: var(--text-sub);
            font-weight: 500;
            margin-bottom: 4px;
            transition: all 0.2s;
        }
        .nav-item:hover, .nav-item.active {
            background-color: #f1f5f9;
            color: var(--primary);
        }
        .nav-item .material-icons { font-size: 22px; }
        .sidebar-spacer { flex-grow: 1; }

        .main-content {
            flex-grow: 1;
            display: flex;
            flex-direction: column;
            height: 100%;
            overflow: hidden;
        }
        .top-bar {
            height: 64px;
            background-color: #ffffff;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 32px;
        }
        .view-title { font-size: 18px; font-weight: 600; }
        .user-profile { display: flex; align-items: center; gap: 12px; font-size: 14px; font-weight: 500;}
        .avatar { width: 32px; height: 32px; background: #e2e8f0; border-radius: 50%; display:flex; align-items:center; justify-content:center; font-weight:bold; color:var(--primary); text-transform: uppercase;}

        /* ==========================================================================
           2. ダッシュボード画面
           ========================================================================== */
        .dashboard-body { padding: 32px; overflow-y: auto; flex-grow: 1; }
        .creator-row { display: flex; gap: 20px; margin-bottom: 40px; }
        .create-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 24px;
            width: 160px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            box-shadow: var(--shadow);
        }
        .create-card:hover { transform: translateY(-2px); border-color: var(--primary); }
        .create-card .material-icons { font-size: 40px; margin-bottom: 12px; }
        .create-card.doc .material-icons { color: #1a73e8; }
        .create-card.slide .material-icons { color: #f4b400; }
        .create-card span { display: block; font-size: 14px; font-weight: 500; }

        .section-title { font-size: 14px; font-weight: 600; color: var(--text-sub); margin-bottom: 16px; text-transform: uppercase; letter-spacing: 0.5px;}
        .file-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; }
        .file-card {
            background: white;
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 16px;
            cursor: pointer;
            transition: border 0.2s;
        }
        .file-card:hover { border-color: var(--primary); }
        .file-icon-row { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; }
        .file-name { font-size: 14px; font-weight: 600; margin-bottom: 4px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .file-date { font-size: 12px; color: var(--text-sub); }

        /* ==========================================================================
           3. ドキュメントエディタ
           ========================================================================== */
        .editor-toolbar {
            height: 48px;
            background-color: #ffffff;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            padding: 0 20px;
            gap: 8px;
        }
        .toolbar-btn {
            background: none;
            border: none;
            padding: 6px;
            border-radius: 6px;
            cursor: pointer;
            display: flex;
            align-items: center;
            color: #475569;
        }
        .toolbar-btn:hover { background-color: #f1f5f9; color: var(--text-main); }
        .editor-container {
            flex-grow: 1;
            padding: 40px;
            overflow-y: auto;
            display: flex;
            justify-content: center;
            background-color: #f1f5f9;
        }
        .document-paper {
            background: white;
            width: 100%;
            max-width: 800px;
            min-height: 1000px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
            padding: 60px 80px;
            outline: none;
            font-size: 16px;
            line-height: 1.6;
        }

        /* ==========================================================================
           4. スライドエディタ
           ========================================================================== */
        .slide-workspace { flex-grow: 1; display: flex; background-color: #e2e8f0; overflow: hidden; }
        .slide-sidebar {
            width: 180px;
            background: white;
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            padding: 16px 12px;
            gap: 12px;
            overflow-y: auto;
        }
        .slide-thumb {
            width: 100%;
            aspect-ratio: 16/9;
            background: #f8fafc;
            border: 2px solid var(--border);
            border-radius: 6px;
            cursor: pointer;
            position: relative;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            color: var(--text-sub);
        }
        .slide-thumb.active { border-color: var(--primary); background-color: #eff6ff; }
        .add-slide-btn {
            border: 2px dashed var(--border);
            background: none;
            padding: 10px;
            border-radius: var(--radius);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            font-weight: 500;
            color: var(--text-sub);
        }
        .add-slide-btn:hover { border-color: var(--primary); color: var(--primary); }
        
        .slide-stage-container {
            flex-grow: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px;
            position: relative;
        }
        #slideCanvas {
            background: white;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            cursor: default;
        }
        #imageUpload { display: none; }
    </style>
</head>
<body>

    <!-- ==========================================
       1. 認証画面（ログイン / 新規登録）
       ========================================== -->
    <div id="authView" class="app-view active">
        <div class="auth-card">
            <div class="auth-logo">MNDI Workspace</div>
            <div id="authSubtitle" class="auth-subtitle">アカウントにログインして開始します</div>
            
            <div class="auth-input-group">
                <label>メールアドレス</label>
                <input type="email" class="auth-input" id="authEmail" value="demo@monndai.com">
            </div>
            <div class="auth-input-group">
                <label>パスワード</label>
                <input type="password" class="auth-input" id="authPassword" value="password123">
            </div>
            
            <!-- サインイン/アップ用メインボタン -->
            <button class="auth-btn" id="authSubmitBtn" onclick="handleAuth()">ログイン</button>
            
            <!-- モード切り替えリンク -->
            <div class="auth-toggle-link" id="authToggleLink" onclick="toggleAuthMode()">初めてですか？ アカウントを作成する</div>
        </div>
    </div>

    <!-- ==========================================
       2. ダッシュボード画面
       ========================================== -->
    <div id="dashboardView" class="app-view">
        <div class="sidebar">
            <div class="sidebar-logo"><span class="material-icons" style="color:var(--primary)">cloud</span>MNDI</div>
            <div class="nav-item active"><span class="material-icons">folder</span>すべてのファイル</div>
            <div class="nav-item"><span class="material-icons">star</span>お気に入り</div>
            <div class="sidebar-spacer"></div>
            <div class="nav-item" onclick="logout()"><span class="material-icons">logout</span>ログアウト</div>
        </div>
        <div class="main-content">
            <div class="top-bar">
                <div class="view-title">マイ ドライブ</div>
                <div class="user-profile">
                    <span id="userDisplayName">demo@monndai.com</span>
                    <div class="avatar" id="userAvatar">D</div>
                </div>
            </div>
            <div class="dashboard-body">
                <div class="section-title">新規作成</div>
                <div class="creator-row">
                    <div class="create-card doc" onclick="createNewFile('doc')">
                        <span class="material-icons">description</span>
                        <span>ドキュメント</span>
                    </div>
                    <div class="create-card slide" onclick="createNewFile('slide')">
                        <span class="material-icons">slideshow</span>
                        <span>スライド</span>
                    </div>
                </div>
                <div class="section-title">最近使用したファイル</div>
                <div class="file-grid" id="fileGrid"></div>
            </div>
        </div>
    </div>

    <!-- ==========================================
       3. ドキュメントエディタ画面
       ========================================== -->
    <div id="docEditorView" class="app-view">
        <div class="sidebar">
            <div class="sidebar-logo" onclick="backToDashboard()" style="cursor:pointer;"><span class="material-icons">arrow_back</span>戻る</div>
            <div class="nav-item active"><span class="material-icons">edit</span>編集</div>
        </div>
        <div class="main-content">
            <div class="top-bar">
                <div class="view-title" id="docTitle">無題のドキュメント</div>
                <button class="auth-btn" style="width:auto; padding:8px 16px; margin:0;" onclick="backToDashboard()">保存して閉じる</button>
            </div>
            <div class="editor-toolbar">
                <button class="toolbar-btn" onclick="document.execCommand('bold')"><span class="material-icons">format_bold</span></button>
                <button class="toolbar-btn" onclick="document.execCommand('italic')"><span class="material-icons">format_italic</span></button>
                <button class="toolbar-btn" onclick="document.execCommand('underline')"><span class="material-icons">format_underlined</span></button>
            </div>
            <div class="editor-container">
                <div class="document-paper" contenteditable="true" id="docBody"></div>
            </div>
        </div>
    </div>

    <!-- ==========================================
       4. スライドエディタ画面
       ========================================== -->
    <div id="slideEditorView" class="app-view">
        <div class="sidebar">
            <div class="sidebar-logo" onclick="backToDashboard()" style="cursor:pointer;"><span class="material-icons">arrow_back</span>戻る</div>
            <div class="nav-item active"><span class="material-icons">layers</span>キャンバス</div>
            <div class="sidebar-spacer"></div>
            <button class="auth-btn" style="padding:10px; font-size:14px;" onclick="backToDashboard()">保存</button>
        </div>
        <div class="main-content">
            <div class="top-bar">
                <div class="view-title" id="slideTitle">無題のスライド</div>
                <div style="display:flex; gap:10px;">
                    <button class="toolbar-btn" style="background:#f1f5f9" onclick="triggerImageUpload()">
                        <span class="material-icons" style="margin-right:6px;">image</span>画像を挿入
                    </button>
                    <input type="file" id="imageUpload" accept="image/*" onchange="handleImageFile(event)">
                </div>
            </div>
            <div class="editor-toolbar">
                <button class="toolbar-btn" onclick="addTextToSlide()"><span class="material-icons">text_fields</span>テキスト追加</button>
            </div>
            <div class="slide-workspace">
                <div class="slide-sidebar">
                    <div class="slide-thumb active">スライド 1</div>
                </div>
                <div class="slide-stage-container">
                    <canvas id="slideCanvas" width="800" height="450"></canvas>
                </div>
            </div>
        </div>
    </div>

    <script>
        // ==========================================================================
        // 認証ロジック & 状態管理
        // ==========================================================================
        let isSignUpMode = false; // false = ログインモード, true = 新規登録モード
        let registeredUsers = {
            'demo@monndai.com': 'password123' // デモ用の初期ユーザー
        };

        let currentUser = null;
        let files = [
            { id: '1', name: '2026年度 事業計画書', type: 'doc', date: '2026/05/10', content: 'これは事前に用意されたデモドキュメントです。自由に書き換えてください。' }
        ];
        let currentEditingFile = null;

        function toggleAuthMode() {
            isSignUpMode = !isSignUpMode;
            const subtitle = document.getElementById('authSubtitle');
            const submitBtn = document.getElementById('authSubmitBtn');
            const toggleLink = document.getElementById('authToggleLink');

            if (isSignUpMode) {
                subtitle.innerText = '新しいWorkspaceアカウントを作成します';
                submitBtn.innerText = 'アカウントを新規登録';
                toggleLink.innerText = 'すでにアカウントをお持ちですか？ ログイン';
            } else {
                subtitle.innerText = 'アカウントにログインして開始します';
                submitBtn.innerText = 'ログイン';
                toggleLink.innerText = '初めてですか？ アカウントを作成する';
            }
        }

        function handleAuth() {
            const email = document.getElementById('authEmail').value.trim();
            const password = document.getElementById('authPassword').value;

            if (!email || !password) {
                alert('メールアドレスとパスワードを入力してください');
                return;
            }

            if (isSignUpMode) {
                // 新規登録処理
                if (registeredUsers[email]) {
                    alert('このメールアドレスは既に登録されています');
                } else {
                    registeredUsers[email] = password;
                    alert('登録が完了しました！自動ログインします。');
                    successLogin(email);
                }
            } else {
                // ログイン処理
                if (registeredUsers[email] && registeredUsers[email] === password) {
                    successLogin(email);
                } else {
                    alert('メールアドレス、またはパスワードが正しくありません');
                }
            }
        }

        function successLogin(email) {
            currentUser = email;
            document.getElementById('userDisplayName').innerText = email;
            document.getElementById('userAvatar').innerText = email.charAt(0);
            renderFileGrid();
            switchView('dashboardView');
        }

        function logout() {
            currentUser = null;
            document.getElementById('authEmail').value = '';
            document.getElementById('authPassword').value = '';
            switchView('authView');
        }

        // ==========================================================================
        // 画面切り替え & エディタ統括
        // ==========================================================================
        function switchView(viewId) {
            document.querySelectorAll('.app-view').forEach(view => view.classList.remove('active'));
            document.getElementById(viewId).classList.add('active');
            if(viewId === 'slideEditorView') {
                initSlideCanvas();
            }
        }

        function backToDashboard() {
            if (currentEditingFile) {
                if (currentEditingFile.type === 'doc') {
                    currentEditingFile.content = document.getElementById('docBody').innerHTML;
                }
            }
            renderFileGrid();
            switchView('dashboardView');
        }

        function renderFileGrid() {
            const grid = document.getElementById('fileGrid');
            grid.innerHTML = '';
            files.forEach(file => {
                const card = document.createElement('div');
                card.className = 'file-card';
                card.onclick = () => openFile(file.id);
                
                const icon = file.type === 'doc' ? 'description' : 'slideshow';
                const iconColor = file.type === 'doc' ? '#1a73e8' : '#f4b400';

                card.innerHTML = `
                    <div class="file-icon-row">
                        <span class="material-icons" style="color:${iconColor}; font-size:28px;">${icon}</span>
                        <span class="material-icons" style="color:var(--text-sub); font-size:18px;">more_vert</span>
                    </div>
                    <div class="file-name">${file.name}</div>
                    <div class="file-date">${file.date}</div>
                `;
                grid.appendChild(card);
            });
        }

        function createNewFile(type) {
            const name = type === 'doc' ? '無題のドキュメント' : '無題のスライド';
            const newFile = {
                id: Date.now().toString(),
                name: name,
                type: type,
                date: new Date().toLocaleDateString(),
                content: type === 'doc' ? 'ここにテキストを入力...' : '',
                elements: type === 'slide' ? [{ type: 'text', x: 200, y: 200, text: 'テキストをダブルクリックして移動', fontSize: 24, color: '#000000' }] : []
            };
            files.unshift(newFile);
            openFile(newFile.id);
        }

        function openFile(id) {
            const file = files.find(f => f.id === id);
            if (!file) return;
            currentEditingFile = file;

            if (file.type === 'doc') {
                document.getElementById('docTitle').innerText = file.name;
                document.getElementById('docBody').innerHTML = file.content;
                switchView('docEditorView');
            } else if (file.type === 'slide') {
                document.getElementById('slideTitle').innerText = file.name;
                slideElements = file.elements;
                switchView('slideEditorView');
            }
        }

        // ==========================================================================
        // スライド Canvas 描画エンジン
        // ==========================================================================
        let sCanvas, sCtx;
        let slideElements = [];
        let selectedElement = null;
        let isDragging = false;
        let dragOffsetX = 0;
        let dragOffsetY = 0;

        function initSlideCanvas() {
            sCanvas = document.getElementById('slideCanvas');
            sCtx = sCanvas.getContext('2d');
            sCanvas.onmousedown = handleCanvasMouseDown;
            sCanvas.onmousemove = handleCanvasMouseMove;
            sCanvas.onmouseup = () => { isDragging = false; };
            drawSlide();
        }

        function drawSlide() {
            sCtx.clearRect(0, 0, sCanvas.width, sCanvas.height);
            sCtx.fillStyle = '#ffffff';
            sCtx.fillRect(0, 0, sCanvas.width, sCanvas.height);

            slideElements.forEach(el => {
                if (el.type === 'text') {
                    sCtx.fillStyle = el.color;
                    sCtx.font = `${el.fontSize}px sans-serif`;
                    sCtx.textBaseline = 'top';
                    sCtx.fillText(el.text, el.x, el.y);
                    
                    if (el === selectedElement) {
                        sCtx.strokeStyle = '#1a73e8';
                        sCtx.lineWidth = 1;
                        const width = sCtx.measureText(el.text).width;
                        sCtx.strokeRect(el.x - 4, el.y - 4, width + 8, el.fontSize + 8);
                    }
                } else if (el.type === 'image' && el.imgObj) {
                    sCtx.drawImage(el.imgObj, el.x, el.y, el.w, el.h);
                    if (el === selectedElement) {
                        sCtx.strokeStyle = '#1a73e8';
                        sCtx.lineWidth = 1;
                        sCtx.strokeRect(el.x, el.y, el.w, el.h);
                    }
                }
            });
        }

        function addTextToSlide() {
            slideElements.push({
                type: 'text',
                x: 150,
                y: 150,
                text: '新規テキスト（ドラッグ可能）',
                fontSize: 24,
                color: '#1e293b'
            });
            drawSlide();
        }

        function triggerImageUpload() {
            document.getElementById('imageUpload').click();
        }

        function handleImageFile(event) {
            const file = event.target.files[0];
            if (!file) return;

            const reader = new FileReader();
            reader.onload = function(e) {
                const img = new Image();
                img.onload = function() {
                    slideElements.push({
                        type: 'image',
                        x: 200,
                        y: 100,
                        w: 240,
                        h: (img.height / img.width) * 240,
                        imgObj: img
                    });
                    drawSlide();
                }
                img.src = e.target.result;
            }
            reader.readAsDataURL(file);
        }

        function handleCanvasMouseDown(e) {
            const rect = sCanvas.getBoundingClientRect();
            const mouseX = e.clientX - rect.left;
            const mouseY = e.clientY - rect.top;
            selectedElement = null;

            for (let i = slideElements.length - 1; i >= 0; i--) {
                const el = slideElements[i];
                if (el.type === 'text') {
                    sCtx.font = `${el.fontSize}px sans-serif`;
                    const width = sCtx.measureText(el.text).width;
                    if (mouseX >= el.x && mouseX <= el.x + width && mouseY >= el.y && mouseY <= el.y + el.fontSize) {
                        selectedElement = el;
                        break;
                    }
                } else if (el.type === 'image') {
                    if (mouseX >= el.x && mouseX <= el.x + el.w && mouseY >= el.y && mouseY <= el.y + el.h) {
                        selectedElement = el;
                        break;
                    }
                }
            }

            if (selectedElement) {
                isDragging = true;
                dragOffsetX = mouseX - selectedElement.x;
                dragOffsetY = mouseY - selectedElement.y;
            }
            drawSlide();
        }

        function handleCanvasMouseMove(e) {
            if (!isDragging || !selectedElement) return;
            const rect = sCanvas.getBoundingClientRect();
            selectedElement.x = e.clientX - rect.left - dragOffsetX;
            selectedElement.y = e.clientY - rect.top - dragOffsetY;
            drawSlide();
        }
    </script>
</body>
